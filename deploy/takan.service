[Unit]
Description=Takan hub (MCP + panel + agents)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=debian
Group=debian
WorkingDirectory=/opt/takan
ExecStart=/opt/takan/takan
EnvironmentFile=/etc/takan/takan.env
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target

TAKAN_LISTEN=127.0.0.1:8090
TAKAN_PUBLIC_URL=https://takan.es
TAKAN_DATA_DIR=/opt/takan/data
TAKAN_SESSION_KEY=change-me-long-random

# Open self-signup without invite (default false = invite required after first user).
# TAKAN_ALLOW_REGISTER=true

# Invites each new user may create (admins can grant unlimited per-user in the panel).
# TAKAN_DEFAULT_INVITE_QUOTA=5

# Extra OAuth redirect hosts (comma-separated), added to built-in Grok/Claude/Cursor/localhost.
# TAKAN_OAUTH_REDIRECT_ALLOW=myapp.example.com

# Rate limits (per minute; 0 = unlimited)
# TAKAN_AUTH_PER_MIN=20
# TAKAN_MACHINE_BASH_PER_MIN=30

# Optional continuous backup (Colmena → S3) — main DB includes Mercadona tables
# TAKAN_BACKUP_ENDPOINT=https://s3.gra.io.cloud.ovh.net
# TAKAN_BACKUP_REGION=gra
# TAKAN_BACKUP_BUCKET=takan-backups
# TAKAN_BACKUP_PREFIX=takan/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

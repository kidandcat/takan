TAKAN_LISTEN=127.0.0.1:8090
TAKAN_PUBLIC_URL=https://takan.es
TAKAN_DATA_DIR=/opt/takan/data
TAKAN_SESSION_KEY=change-me-long-random

# Optional continuous backup (Colmena → S3)
# TAKAN_BACKUP_ENDPOINT=https://s3.gra.io.cloud.ovh.net
# TAKAN_BACKUP_REGION=gra
# TAKAN_BACKUP_BUCKET=takan-backups
# TAKAN_BACKUP_PREFIX=takan/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional public file shares (Files module — OVH Object Storage / S3-compatible)
# TAKAN_FILES_ENDPOINT=https://s3.gra.io.cloud.ovh.net
# TAKAN_FILES_REGION=gra
# TAKAN_FILES_BUCKET=takan-public
# TAKAN_FILES_PREFIX=takan-files/
# TAKAN_FILES_ACCESS_KEY=
# TAKAN_FILES_SECRET_KEY=
# Public URL prefix for objects (bucket/CDN). If empty, uses https://bucket.endpoint/key
# TAKAN_FILES_PUBLIC_BASE=https://storage.gra.cloud.ovh.net/v1/AUTH_xxx/takan-public
